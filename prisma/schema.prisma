// VelaraPay — PostgreSQL schema (Prisma)
// Multi-tenant: every financial row is scoped to an Organization.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  admin
  treasurer
  analyst
  viewer
}

enum UserStatus {
  active
  invited
  suspended
}

enum Currency {
  USD
  EUR
  GBP
  SAR
  AED
  KWD
  QAR
}

enum CryptoAsset {
  BTC
  ETH
  USDT
  USDC
}

enum BatchStatus {
  draft
  processing
  completed
  failed
}

enum TxType {
  incoming
  outgoing
  conversion
  fee
}

enum TxStatus {
  completed
  pending
  processing
  failed
}

model Organization {
  id           String         @id @default(cuid())
  name         String
  baseCurrency Currency       @default(USD)
  /// Trading margin (FX spread) applied to this client's conversions, in
  /// basis points. 50 bps = 0.50%. Adjustable from the back office.
  marginBps    Int            @default(50)
  createdAt    DateTime       @default(now())
  users        User[]
  wallets      Wallet[]
  cryptoWallets CryptoWallet[]
  transactions Transaction[]
  beneficiaries Beneficiary[]
  batches      PaymentBatch[]
}

model User {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email        String       @unique
  username     String?      @unique
  name         String
  initials     String
  passwordHash String
  role         Role         @default(viewer)
  /// Platform-level back-office operator. Bypasses org RBAC and can access
  /// the /admin area to view every account and adjust client margins.
  isSuperadmin Boolean      @default(false)
  status       UserStatus   @default(active)
  twoFactor    Boolean      @default(false)
  lastActiveAt DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     Session[]

  @@index([orgId])
}

/// Opaque, revocable server-side sessions. The cookie holds the raw token;
/// only its SHA-256 hash is persisted, so a DB leak can't be replayed.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

model Wallet {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  currency  Currency
  balance   Decimal      @db.Decimal(24, 4)
  reserved  Decimal      @default(0) @db.Decimal(24, 4)
  change24h Float        @default(0)
  reference String
  isPrimary Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@unique([orgId, currency])
  @@index([orgId])
}

model Transaction {
  id                   String        @id @default(cuid())
  orgId                String
  org                  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reference            String
  type                 TxType
  status               TxStatus
  counterparty         String
  counterpartyInitials String
  amountCurrency       Currency
  amountValue          Decimal       @db.Decimal(24, 4)
  convertedCurrency    Currency?
  convertedValue       Decimal?      @db.Decimal(24, 4)
  rate                 Decimal?      @db.Decimal(20, 8)
  fee                  Decimal       @default(0) @db.Decimal(24, 4)
  category             String
  countryFlag          String
  beneficiaryId        String?
  beneficiary          Beneficiary?  @relation(fields: [beneficiaryId], references: [id], onDelete: SetNull)
  batchId              String?
  batch                PaymentBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, type])
  @@index([orgId, status])
  @@index([batchId])
}

/// A crypto holding (tracked balance + 24h change). Valued against a live
/// USD price feed in the app; no on-chain custody.
model CryptoWallet {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset     CryptoAsset
  balance   Decimal      @db.Decimal(36, 8)
  change24h Float        @default(0)
  address   String
  createdAt DateTime     @default(now())

  @@unique([orgId, asset])
  @@index([orgId])
}

/// A saved payee (bank details) a client pays out to.
model Beneficiary {
  id            String        @id @default(cuid())
  orgId         String
  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  nickname      String?
  bankName      String
  accountNumber String
  iban          String?
  swift         String
  currency      Currency
  country       String
  countryFlag   String
  createdAt     DateTime      @default(now())
  transactions  Transaction[]

  @@index([orgId])
}

/// A bulk payment run created from a CSV upload.
model PaymentBatch {
  id           String        @id @default(cuid())
  orgId        String
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  filename     String
  status       BatchStatus   @default(processing)
  totalCount   Int
  totalValue   Decimal       @db.Decimal(24, 4)
  baseCurrency Currency      @default(USD)
  createdAt    DateTime      @default(now())
  createdBy    String
  transactions Transaction[]

  @@index([orgId, createdAt])
}
