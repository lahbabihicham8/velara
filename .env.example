# ──────────────────────────────────────────────────────────────
# VelaraPay environment configuration
# Copy to `.env` and fill in real values.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
# Local (docker-compose): postgres running on :5432
DATABASE_URL="postgresql://velarapay:velarapay@localhost:5432/velarapay?schema=public"

# Session lifetime in days (DB-backed sessions).
SESSION_TTL_DAYS=7

# Bcrypt cost factor for password hashing (10–12 recommended).
PASSWORD_SALT_ROUNDS=12

# Handover password applied to all seeded users (CHANGE/REMOVE in production).
SEED_PASSWORD="velara2026"
